## Introduction

This report details the analysis of Qubit data collected over a 7-day experiment. The goal is to determine if Qubit values, a proxy for a biological measurement like DNA concentration, are related to the addition of different glucose concentrations (Water, 5mg/ml, 10mg/ml, 20mg/ml) over time.

------------------------------------------------------------------------

## 1. Data Loading and Tidying

```{r data-tidying, message=FALSE, warning=FALSE}
#| include: false
# R Script to Parse Experimental Qubit Data and Create a Tidy Dataframe

# --- 1. Raw Data Input ---
# Storing the data provided in a multi-line string.
raw_data_string <- "
day 1: W1-208 W2-413 W3-295 51-148 52-281 53-215 101-17 102-169 103-232 201-131 202-131 203-95.3
day 3: W1-139 W2-295 W3-260 51-128 52-90 53-222 101-347 102-195 103-228 201-278 202-211 203-256
day 5: W1-207 W2-333 W3-275 51-211 52-153 53-193 101-249 102-246 103-224 201-267 202-267 203-193
day 7: W1-165 W2-113 W3-214 51-201 52-279 53-340 101-211 102-223 103-251 201-267 202-241 203-275
"

# --- 2. Data Processing ---
lines <- strsplit(raw_data_string, "\n")[[1]]
lines <- lines[lines != ""]
data_list <- list()

for (current_line in lines) {
  day_num <- as.numeric(gsub("day (\\d+):.*", "\\1", current_line))
  measurements_str <- gsub("day \\d+: (.*)", "\\1", current_line)
  measurements <- strsplit(measurements_str, " ")[[1]]
  
  for (measurement in measurements) {
    parts <- strsplit(measurement, "-")[[1]]
    sample_id <- parts[1]
    qubit_value <- as.numeric(parts[2])
    
    concentration <- NA
    replicate_num <- NA
    
    if (startsWith(sample_id, "W")) {
      concentration <- "Water"
      replicate_num <- as.numeric(gsub("W", "", sample_id))
    } else if (startsWith(sample_id, "20")) {
      concentration <- "20mg/ml"
      replicate_num <- as.numeric(substring(sample_id, 3))
    } else if (startsWith(sample_id, "10")) {
      concentration <- "10mg/ml"
      replicate_num <- as.numeric(substring(sample_id, 3))
    } else if (startsWith(sample_id, "5")) {
      concentration <- "5mg/ml"
      replicate_num <- as.numeric(substring(sample_id, 2))
    }
    
    data_list[[length(data_list) + 1]] <- data.frame(
      Day = day_num,
      Concentration = concentration,
      Replicate = replicate_num,
      QubitValue = qubit_value
    )
  }
}

qubit_df <- do.call(rbind, data_list)

# --- 3. Final Touches ---
concentration_levels <- c("Water", "5mg/ml", "10mg/ml", "20mg/ml")
qubit_df$Concentration <- factor(qubit_df$Concentration, levels = concentration_levels)
rownames(qubit_df) <- NULL

# --- 4. Display the Result ---
print("Data successfully converted into a tidy dataframe!")
knitr::kable(head(qubit_df), caption = "First 6 Rows of the Tidy Dataframe")
```

